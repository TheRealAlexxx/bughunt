{
  "version": 2,
  "public": true,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api",
      "dest": "/api/index.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "/bughunt/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/bughunt/index.html"
    }
  ]
}
